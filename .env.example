# Required
OPENAI_API_KEY=sk-...

# Optional - Enhanced scraping
FIRECRAWL_API_KEY=

# Optional - Domain analytics
SEMRUSH_API_KEY=

# Optional - Supabase (for auth + persistence)
# Server-side (used by Hono backend)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Client-side (used by React frontend via Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional - Production
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173
