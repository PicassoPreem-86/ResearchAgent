{
  "name": "research-agent",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch src/server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production tsx src/server/index.ts",
    "docker:build": "docker build -t research-agent .",
    "docker:run": "docker run -p 3001:3001 --env-file .env research-agent",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@mendable/firecrawl-js": "^4.12.1",
    "@supabase/supabase-js": "^2.95.3",
    "cheerio": "^1.0.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^11.15.0",
    "hono": "^4.6.0",
    "lucide-react": "^0.468.0",
    "openai": "^6.21.0",
    "pdfkit": "^0.17.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "happy-dom": "^20.6.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
